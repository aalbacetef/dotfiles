
set $term bash -lc alacritty
set $wallpaper /personal-files/dotfiles/wallpaper/wallpaper.png
set $wofi_style_css ~/config/wofi/style.css 

set $gaps_inner 5
set $gaps_outer 15

set $mainMod Mod4

output * bg #1e1e2e solid_color
output * position 0,0
output * scale 1

input "type:keyboard" {
    xkb_layout us
}

input "type:touchpad" {
    natural_scroll disabled
    tap enabled
    dwt enabled
}

focus_follows_mouse yes
mouse_warping output

gaps inner $gaps_inner
gaps outer $gaps_outer

default_border pixel 2
default_floating_border pixel 2

client.focused          #33ccff #00ff99 #ffffff #33ccff #33ccff
client.unfocused        #595959 #2a2a2a #888888 #595959 #595959
client.urgent           #ff5555 #ff5555 #ffffff #ff5555 #ff5555
client.placeholder      #000000 #0c0c0c #ffffff #000000 #000000
client.background       #ffffff

smart_gaps off
smart_borders off

for_window [class=".*"] border pixel 2
floating_modifier $mainMod

bindsym $mainMod+space exec wofi --show drun -i
bindsym $mainMod+Return exec alacritty
bindsym Ctrl+Alt+t exec alacritty

bindsym $mainMod+q kill
bindsym $mainMod+f fullscreen toggle
bindsym $mainMod+v floating toggle
bindsym $mainMod+j split toggle

bindsym $mainMod+l+s layout stacking
bindsym $mainMod+l+t layout tabbed 
bindsym $mainMod+l+p layout toggle split
bindsym $mainMod+Shift+l layout default

bindsym $mainMod+Left  focus left
bindsym $mainMod+Right focus right
bindsym $mainMod+Up    focus up
bindsym $mainMod+Down  focus down
bindsym $mainMod+Shift+p focus parent

bindsym $mainMod+Shift+Left  move left
bindsym $mainMod+Shift+Right move right
bindsym $mainMod+Shift+Up    move up
bindsym $mainMod+Shift+Down  move down

bindsym $mainMod+Ctrl+Left  resize shrink width 50px
bindsym $mainMod+Ctrl+Right resize grow   width 50px
bindsym $mainMod+Ctrl+Up    resize shrink height 50px
bindsym $mainMod+Ctrl+Down  resize grow   height 50px

bindsym $mainMod+button1 move
bindsym $mainMod+button3 resize

bindsym $mainMod+1 workspace number 1
bindsym $mainMod+2 workspace number 2
bindsym $mainMod+3 workspace number 3
bindsym $mainMod+4 workspace number 4
bindsym $mainMod+5 workspace number 5
bindsym $mainMod+6 workspace number 6
bindsym $mainMod+7 workspace number 7
bindsym $mainMod+8 workspace number 8
bindsym $mainMod+9 workspace number 9
bindsym $mainMod+0 workspace number 10

bindsym $mainMod+Shift+1 move container to workspace number 1
bindsym $mainMod+Shift+2 move container to workspace number 2
bindsym $mainMod+Shift+3 move container to workspace number 3
bindsym $mainMod+Shift+4 move container to workspace number 4
bindsym $mainMod+Shift+5 move container to workspace number 5
bindsym $mainMod+Shift+6 move container to workspace number 6
bindsym $mainMod+Shift+7 move container to workspace number 7
bindsym $mainMod+Shift+8 move container to workspace number 8
bindsym $mainMod+Shift+9 move container to workspace number 9
bindsym $mainMod+Shift+0 move container to workspace number 10

bindsym $mainMod+p layout toggle split

bindsym $mainMod+Shift+r reload
bindsym $mainMod+Shift+q exit

bindsym $mainMod+Tab focus next
bindsym $mainMod+question exec ~/.config/waybar/show-keybinds.sh
# bindsym $mainMod+d exec wofi --show drun -i --style $wofi_style_css --allow-images
bindsym $mainMod+d exec nwggrid

exec mako
exec wl-paste --watch cliphist store
exec nm-applet --indicator
exec swaybg -i $wallpaper -m fill
exec blueman-applet
exec eww kill
exec eww daemon

bar {
    swaybar_command waybar
}

for_window [class="Wofi"] floating enable, resize set 800 600, move position center

exec_always ~/.config/picom/launch-picom.sh
